# vets-anni environment — copy to .env and fill in. .env is gitignored.
# On the VPS this lives in vets-deploy/stacks/vets-anni/.env (see that stack's README).

# --- Discord (fishbot) -------------------------------------------------------
FISHBOT_TOKEN=                       # Discord bot token for fishbot
RSVP_CHANNEL_ID=                     # Channel id where fishbot posts public RSVP
                                     # confirmation lines (defaults to the anni channel).
                                     # Replies to the user stay ephemeral; the public
                                     # line is a record/visibility ack.

# --- Wynncraft API (OWN token; separate ratelimit bucket) --------------------
WAPI_TOKEN=                          # vets-anni's OWN Wynncraft v3 token. MUST NOT be
                                     # the dazebot/temporary-server token — separate
                                     # ratelimit bucket is mandated by the spec.

# --- Web auth (intentionally low-trust coordination tool, not security) ------
SESSION_SECRET=                      # itsdangerous cookie signing key. Generate with
                                     #   python -c "import secrets;print(secrets.token_hex(32))"
STAFF_PASSWORD=                      # Initial staff password. Hashed into AppConfig on
                                     # first boot; rotate in-app afterwards.
ADMIN_PASSWORD=                      # Gate for the staff-password rotate route.

# --- Domain config -----------------------------------------------------------
ALLY_GUILD_ID=                       # Wynncraft guild id (or name) treated as "Ally".
RETURNERS_GUILD_NAME=Returners       # The vets guild name (membership = MEMBER).

# --- Sibling service integration --------------------------------------------
VETS_API_BASE=https://api.wynnvets.org
DAZEBOT_INTROSPECT_SECRET=           # MUST match dazebot/.env. Auth for the dazebot
                                     # POST /api/internal/anni-identity endpoint.
DAZEBOT_ANNI_IDENTITY_URL=http://dazebot:9421/api/internal/anni-identity
                                     # Internal verify-network URL. CONFIRM the dazebot
                                     # port from vets-deploy/stacks/dazebot/.env
                                     # (picolimbo uses 9421) — do not assume blindly.

# --- Misc --------------------------------------------------------------------
PUBLIC_BASE_URL=https://anni.wynnvets.org   # used for the /rsvp dashboard deep-link
ANNI_DB_PATH=./data/anni.db                 # Docker overrides to /app/data/anni.db
DEBUG=true                                  # local dev default; the deploy stack
                                            # .env sets this false for production

